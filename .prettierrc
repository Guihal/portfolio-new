{
    "tabWidth": 4,
    "semi": true,
    "singleQuote": true,
    "printWidth": 80,
    "bracketSpacing": true,
    "bracketSameLine": true,
    "vueIndentScriptAndStyle": true,
    "overrides": [
        {
            "files": ["*.vue"],
            "options": {
                "parser": "vue"
            }
        }
    ]
}
