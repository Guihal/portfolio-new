{
    "name": "portfolio-new",
    "type": "module",
    "private": true,
    "scripts": {
        "build": "bun run generate:manifests && nuxt build",
        "generate:manifest": "bun scripts/generate-manifest.ts",
        "generate:file-manifest": "bun scripts/generate-file-manifest.ts",
        "generate:manifests": "bun run generate:manifest && bun run generate:file-manifest",
        "dev": "bun run generate:manifests && nuxt dev",
        "generate": "bun run generate:manifests && nuxt generate",
        "preview": "nuxt preview",
        "postinstall": "nuxt prepare",
        "lint": "eslint .",
        "typecheck": "nuxi typecheck",
        "biome:check": "biome check .",
        "test:unit": "vitest run",
        "test:unit:watch": "vitest",
        "test:e2e": "playwright test"
    },
    "dependencies": {
        "@nuxt/eslint": "1.15.1",
        "@nuxt/image": "2.0.0",
        "@pinia/nuxt": "0.11.3",
        "html-to-image": "^1.11.13",
        "nuxt": "^4.3.1",
        "vue": "^3.5.28",
        "vue-router": "^4.6.4",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.4",
        "@playwright/test": "^1.59.1",
        "@types/bun": "^1.3.9",
        "@types/node": "^25.3.0",
        "@vue/test-utils": "^2.4.6",
        "bun-types": "^1.3.9",
        "jsdom": "^29.0.2",
        "lefthook": "^2.1.6",
        "sass": "^1.97.3",
        "vitest": "^4.1.4"
    }
}
